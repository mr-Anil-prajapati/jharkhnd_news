---
import '../styles/global.css';

const { title, description } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path = '') => `${baseUrl.replace(/\/$/, '')}/${path}`.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | Jharkhand News</title>
  <meta name="description" content={description || 'Latest news from Jharkhand - Jobs, Sports, Entertainment, Education and more'}>
  <meta name="keywords" content="Jharkhand news, Ranchi news, Jamshedpur news, Sarkari Naukri, Jobs in Jharkhand">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')}>
</head>
<body class="site-body">
  <div class="page-orb page-orb-left"></div>
  <div class="page-orb page-orb-right"></div>

  <header class="site-header">
    <div class="topbar">
      <div class="shell topbar-inner">
        <p class="topbar-label">Premium Hindi Newsroom</p>
        <div class="ticker-track" aria-label="Latest headlines">
          <div class="ticker-content">
            <span>रांची में विकास परियोजनाओं पर नई समीक्षा बैठक</span>
            <span>सरकारी नौकरी अपडेट्स और एडमिट कार्ड अलर्ट</span>
            <span>झारखंड खेल और शिक्षा की बड़ी खबरें एक ही जगह</span>
          </div>
        </div>
      </div>
    </div>

    <div class="shell masthead">
      <a href={withBase()} class="brand-mark">
        <span class="brand-badge">JH</span>
        <span>
          <strong>झारखंड न्यूज़</strong>
          <small>State, jobs, culture and breaking reports</small>
        </span>
      </a>

      <nav class="nav-links" aria-label="Primary">
        <a href={withBase()}>होम</a>
        <a href={withBase('category/jharkhand')}>झारखंड</a>
        <a href={withBase('category/jobs')}>नौकरी</a>
        <a href={withBase('category/sports')}>खेल</a>
        <a href={withBase('category/entertainment')}>मनोरंजन</a>
        <a href={withBase('category/education')}>शिक्षा</a>
      </nav>

      <details class="mobile-nav">
        <summary>मेन्यू</summary>
        <div class="mobile-nav-panel">
          <a href={withBase()}>होम</a>
          <a href={withBase('category/jharkhand')}>झारखंड</a>
          <a href={withBase('category/jobs')}>नौकरी</a>
          <a href={withBase('category/sports')}>खेल</a>
          <a href={withBase('category/entertainment')}>मनोरंजन</a>
          <a href={withBase('category/education')}>शिक्षा</a>
        </div>
      </details>
    </div>
  </header>

  <main class="shell site-main">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="shell footer-grid">
      <div>
        <p class="footer-kicker">Jharkhand's digital front page</p>
        <h2 class="footer-brand">झारखंड न्यूज़</h2>
        <p class="footer-copy">राज्य, रोजगार, शिक्षा, खेल और संस्कृति की साफ, तेज और प्रीमियम प्रस्तुति।</p>
      </div>
      <div>
        <h3 class="footer-title">Sections</h3>
        <div class="footer-links">
          <a href={withBase('category/jharkhand')}>झारखंड</a>
          <a href={withBase('category/jobs')}>नौकरी</a>
          <a href={withBase('category/sports')}>खेल</a>
          <a href={withBase('category/education')}>शिक्षा</a>
        </div>
      </div>
      <div>
        <h3 class="footer-title">About The Desk</h3>
        <p class="footer-copy">Designed as a modern editorial experience with strong typography, layered cards, and fast category navigation.</p>
      </div>
    </div>
    <div class="shell footer-meta">
      <span>© 2026 Jharkhand News</span>
      <span>Built for GitHub Pages</span>
    </div>
  </footer>
</body>
</html>
